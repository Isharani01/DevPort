@page "/"
@using DevPort.Data
@using DevPort.Models
@inject ApplicationDbContext db

<!-- HERO SECTION -->

<section class="hero-section">

    <div class="hero-content">

        <p class="hero-tag">
            🚀 Full Stack Developer Portfolio
        </p>

        <h1>
            Build Stunning
            <span class="gradient-text">
                Developer Portfolios
            </span>
        </h1>

        <p class="hero-description">

            DevPort helps developers showcase
            projects, skills and achievements
            with a modern portfolio experience.

        </p>

        <div class="hero-buttons">

            <a href="/projects"
                   class="btn btn-primary btn-lg">

                View Projects

            </a>

            <a href="/profile"
                   class="btn btn-outline-light btn-lg">

                My Profile

            </a>

        </div>

    </div>

</section>

<!-- ABOUT -->

<section class="mb-5">

    <h2 class="mb-4">
        About Me
    </h2>

    @if (profile != null)
    {
        <div class="card-ui">

            <h3>@profile.Name</h3>

            <p>@profile.About</p>

            <p>
                📞 @profile.Phone
            </p>

        </div>
    }
    else
    {
        <div class="card-ui">
            <p>No profile found.</p>
        </div>
    }

</section>

<!-- SKILLS -->

<section class="mb-5">

    <h2 class="mb-4">
        Skills
    </h2>

    @if (skills.Count == 0)
    {
        <div class="card-ui">
            <p>No skills added yet.</p>
        </div>
    }
    else
    {
        <div class="card-ui">

            @foreach (var s in skills)
            {
                <span class="skill-badge">
                    @s.Name
                </span>
            }

        </div>
    }

</section>

<!-- PROJECTS -->

<section class="mb-5">

    <h2 class="mb-4">
        Projects
    </h2>

    @if (projects.Count == 0)
    {
        <div class="card-ui">
            <p>No projects added yet.</p>
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var p in projects)
            {
                <div class="col-md-6">

                    <div class="card-ui project-card">

                        <h4>@p.Title</h4>

                        <p>@p.Description</p>

                    </div>

                </div>
            }

        </div>
    }

</section>

<!-- STATS -->

<section class="stats-section">

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card-ui stats-card">

                <h2>@projects.Count+</h2>

                <p>Projects Built</p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card-ui stats-card">

                <h2>@skills.Count+</h2>

                <p>Skills Added</p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card-ui stats-card">

                <h2>100%</h2>

                <p>Responsive UI</p>

            </div>

        </div>

    </div>

</section>

@code {

    private DevPort.Models.Profile? profile;

    private List<Skill> skills = new();

    private List<Project> projects = new();

    protected override void OnInitialized()
    {
        profile = db.Profiles
            .OrderByDescending(x => x.Id)
            .FirstOrDefault();

        skills = db.Skills.ToList();

        projects = db.Projects.ToList();
    }
}
@page "/"

<!-- HERO SECTION -->

<section class="landing-hero">

    <div class="hero-container">

        <p class="hero-badge">
            ✨ Modern Developer Portfolio Platform
        </p>

        <h1>
            Build Your
            Digital Presence
        </h1>

        <p class="hero-subtitle">

            Create a beautiful portfolio,
            showcase your skills,
            projects and achievements
            with DevPort.

        </p>

        <!-- BUTTONS -->

        <div class="hero-actions">

            <a href="/profile"
                   class="start-btn">

                Create Profile

            </a>

            <a href="/projects"
                   class="login-btn">

                View Projects

            </a>

        </div>

    </div>

</section>

<!-- ABOUT SECTION -->

<section id="about"
         class="about-section">

    <div class="container">

        <div class="section-title">

            <h2>
                Why DevPort?
            </h2>

            <p>
                Everything you need to build
                a modern developer portfolio.
            </p>

        </div>

        <div class="about-grid">

            <!-- CARD 1 -->

            <div class="about-card">

                <h3>
                    🚀 Modern Design
                </h3>

                <p>

                    Clean and premium portfolio
                    layouts inspired by modern
                    SaaS websites.

                </p>

            </div>

            <!-- CARD 2 -->

            <div class="about-card">

                <h3>
                    💼 Professional Profiles
                </h3>

                <p>

                    Showcase your education,
                    experience, technologies
                    and achievements beautifully.

                </p>

            </div>

            <!-- CARD 3 -->

            <div class="about-card">

                <h3>
                    ⚡ Fast & Responsive
                </h3>

                <p>

                    Built with Blazor for
                    smooth performance and
                    responsive experience.

                </p>

            </div>

        </div>

    </div>

</section>

<!-- FEATURES SECTION -->

<section id="projects"
         class="projects-section">

    <div class="container">

        <div class="section-title">

            <h2>
                Portfolio Features
            </h2>

            <p>
                Build your complete online presence.
            </p>

        </div>

        <div class="projects-grid">

            <!-- FEATURE 1 -->

            <div class="project-card">

                <h3>
                    🌐 Create Portfolio
                </h3>

                <p>

                    Build your professional
                    portfolio website with
                    elegant templates.

                </p>

            </div>

            <!-- FEATURE 2 -->

            <div class="project-card">

                <h3>
                    🛠 Showcase Skills
                </h3>

                <p>

                    Add your technologies,
                    tools and expertise with
                    beautiful UI sections.

                </p>

            </div>

            <!-- FEATURE 3 -->

            <div class="project-card">

                <h3>
                    📁 Display Projects
                </h3>

                <p>

                    Upload and present your
                    best projects professionally
                    to recruiters and clients.

                </p>

            </div>

        </div>

    </div>

</section>

<!-- CTA SECTION -->

<section class="about-section">

    <div class="container">

        <div class="section-title">

            <h2>
                Start Building Today 🚀
            </h2>

            <p>
                Create your modern developer
                portfolio in minutes.
            </p>

        </div>

        <div class="hero-actions">

            <a href="/Account/Register"
                   class="start-btn">

                Get Started

            </a>

        </div>

    </div>

</section>

<!-- FOOTER -->

<section id="contact"
         class="footer-section">

    <h2>
        DevPort 🚀
    </h2>

    <p>
        A modern platform for developers
        to create professional portfolios.
    </p>

    <div class="footer-links">

        <a href="/">
            Home
        </a>

        <a href="#about">
            About
        </a>

        <a href="#projects">
            Features
        </a>

        <a href="/Account/Register">
            Register
        </a>

    </div>

    <p class="copyright-text">
        © 2026 DevPort. All rights reserved.
    </p>

</section>
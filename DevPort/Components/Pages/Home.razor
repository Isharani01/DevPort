@page "/"

<!-- HERO -->

<section class="landing-hero">

    <div class="hero-container">

        <p class="hero-badge">
            ✨ Build Your Developer Presence
        </p>

        <h1>
            Create Beautiful
            Developer Portfolios
        </h1>

        <p class="hero-subtitle">

            DevPort helps developers showcase
            projects, skills and achievements
            with a stunning modern portfolio platform.

        </p>

        <div class="hero-actions">

            <a href="/template"
                   class="btn btn-primary btn-lg">

                Explore Templates

            </a>

            <a href="/profile"
                   class="btn btn-outline-light btn-lg">

                Get Started

            </a>

        </div>

    </div>

</section>

<!-- FEATURES -->

<section class="landing-section">

    <div class="section-title">

        <h2>
            Everything You Need
        </h2>

        <p>
            Build modern developer portfolios effortlessly.
        </p>

    </div>

    <div class="features-grid">

        <div class="feature-card-modern">

            <h3>🎨 Modern UI</h3>

            <p>
                Beautiful responsive layouts
                with premium design.
            </p>

        </div>

        <div class="feature-card-modern">

            <h3>⚡ Fast Performance</h3>

            <p>
                Optimized Blazor application
                with smooth experience.
            </p>

        </div>

        <div class="feature-card-modern">

            <h3>🌙 Dark Mode</h3>

            <p>
                Elegant dark and light
                theme support.
            </p>

        </div>

    </div>

</section>

<!-- CTA -->

<section class="cta-section">

    <div class="cta-box">

        <h2>
            Start Building Today 🚀
        </h2>

        <p>
            Create your modern developer portfolio in minutes.
        </p>

        <a href="/Account/Register"
               class="btn btn-primary btn-lg">

            Create Account

        </a>

    </div>

</section>
@page "/"
@using DevPort.Data
@using DevPort.Models
@inject ApplicationDbContext db

<h1>My Portfolio 🚀</h1>

<p>Welcome to my DevPort profile</p>

<hr />

<h2>About Me</h2>

@if (profile != null)
{
    <div style="border:1px solid gray; padding:10px; margin-bottom:20px;">
        <h3>@profile.Name</h3>
        <p>@profile.About</p>
        <p>@profile.Phone</p>
    </div>
}
else
{
    <p>No profile found.</p>
}

<h2>Skills</h2>

@if (skills.Count == 0)
{
    <p>No skills added yet.</p>
}
else
{
    @foreach (var s in skills)
    {
        <span style="display:inline-block; padding:5px; margin:5px; border:1px solid black;">
            @s.Name
        </span>
    }
}

<h2>Projects</h2>

@if (projects.Count == 0)
{
    <p>No projects added yet.</p>
}
else
{
    @foreach (var p in projects)
    {
        <div style="border:1px solid gray; padding:10px; margin:10px;">
            <h4>@p.Title</h4>
            <p>@p.Description</p>
        </div>
    }
}

@code {

    private DevPort.Models.Profile? profile;
    private List<Skill> skills = new();
    private List<Project> projects = new();

    protected override void OnInitialized()
    {
        profile = db.Profiles
            .OrderByDescending(x => x.Id)
            .FirstOrDefault();

        skills = db.Skills.ToList();
        projects = db.Projects.ToList();
    }
}


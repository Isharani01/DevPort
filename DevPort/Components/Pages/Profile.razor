@page "/test-projects"
@using DevPort.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject DevPort.Data.ApplicationDbContext db
@inject AuthenticationStateProvider AuthStateProvider

<h3 class="mb-3">My Projects</h3>

<!-- INPUT SECTION -->
<div class="card-ui">

    <input class="form-control mb-2"
           placeholder="Project Title"
           @bind="project.Title" />

    <textarea class="form-control mb-2"
              placeholder="Project Description"
              @bind="project.Description"></textarea>

    <button class="btn btn-primary w-100"
            @onclick="SaveProject">
        Save Project
    </button>

    @if (!string.IsNullOrEmpty(message))
    {
        <p class="text-success mt-2 mb-0">@message</p>
    }

</div>

<hr />

<!-- LIST -->
@if (projects == null || projects.Count == 0)
{
    <p>No projects found.</p>
}
else
{
    @foreach (var p in projects)
    {
        <div class="card-ui">

            <h4 class="mb-1">@p.Title</h4>
            <p class="mb-2">@p.Description</p>

            <button class="btn btn-danger btn-sm"
                    @onclick="() => DeleteProject(p.Id)">
                Delete
            </button>

        </div>
    }
}

@code {

    private Project project = new();
    private List<Project> projects = new();

    private string message = "";
    private string userId = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

        LoadProjects();
    }

    private void LoadProjects()
    {
        projects = db.Projects
            .Where(x => x.UserId == userId)
            .ToList();
    }

    private async Task SaveProject()
    {
        if (string.IsNullOrWhiteSpace(project.Title))
        {
            message = "Title is required!";
            return;
        }

        project.UserId = userId;

        db.Add(project);
        await db.SaveChangesAsync();

        project = new Project();
        message = "Project saved successfully!";

        LoadProjects();
    }

    private async Task DeleteProject(int id)
    {
        var item = db.Projects
            .FirstOrDefault(x => x.Id == id && x.UserId == userId);

        if (item != null)
        {
            db.Remove(item);
            await db.SaveChangesAsync();
        }

        LoadProjects();
    }
}
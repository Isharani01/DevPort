@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="@(isDarkMode ? "dark-mode" : "light-mode")">

    <!-- NAVBAR -->

    <nav class="navbar navbar-expand-lg custom-navbar px-4">

        <a class="navbar-brand fw-bold fs-4" href="/">
            DevPort 🚀
        </a>

        <!-- TOGGLER -->

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navMenu">

            <span class="navbar-toggler-icon"></span>

        </button>

        <!-- NAV MENU -->

        <div class="collapse navbar-collapse"
             id="navMenu">

            <ul class="navbar-nav ms-auto align-items-center gap-3">

                <!-- HOME -->

                <li class="nav-item">

                    <NavLink class="nav-link"
                             href="/">

                        Home

                    </NavLink>

                </li>

                <!-- TEMPLATES -->

                <li class="nav-item">

                    <NavLink class="nav-link"
                             href="/template">

                        Templates

                    </NavLink>

                </li>

                <!-- PORTFOLIO -->

                <li class="nav-item">

                    <NavLink class="nav-link"
                             href="/portfolio">

                        Portfolio

                    </NavLink>

                </li>

                <!-- THEME BUTTON -->

                <li class="nav-item">

                    <button class="theme-toggle-btn"
                            @onclick="ToggleTheme">

                        @(isDarkMode ? "☀️" : "🌙")

                    </button>

                </li>

                <!-- AUTH -->

                <AuthorizeView>

                    <Authorized>

                        <li class="nav-item">

                            <form action="/Account/Logout"
                                  method="post">

                                <AntiforgeryToken />

                                <button type="submit"
                                        class="btn btn-outline-light rounded-pill px-4">

                                    Logout

                                </button>

                            </form>

                        </li>

                    </Authorized>

                    <NotAuthorized>

                        <li class="nav-item">

                            <NavLink class="btn btn-outline-light rounded-pill px-4"
                                     href="/Account/Login">

                                Login

                            </NavLink>

                        </li>

                        <li class="nav-item">

                            <NavLink class="btn btn-primary rounded-pill px-4"
                                     href="/Account/Register">

                                Get Started

                            </NavLink>

                        </li>

                    </NotAuthorized>

                </AuthorizeView>

            </ul>

        </div>

    </nav>

    <!-- PAGE CONTENT -->

    <main class="container py-4">

        @Body

    </main>

</div>

@code {

    private bool isDarkMode = true;

    private void ToggleTheme()
    {
        isDarkMode = !isDarkMode;
    }
}
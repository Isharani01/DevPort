@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="dark-mode">

    <!-- NAVBAR -->

    <nav class="navbar navbar-expand-lg custom-navbar">

        <div class="container">

            <!-- LOGO -->

            <a class="navbar-brand" href="/">
                DevPort 🚀
            </a>

            <!-- MOBILE BUTTON -->

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">

                <span class="navbar-toggler-icon"></span>

            </button>

            <!-- NAVIGATION -->

            <div class="collapse navbar-collapse"
                 id="navbarContent">

                <ul class="navbar-nav ms-auto align-items-center">

                    <!-- LINKS -->

                    <li class="nav-item">

                        <a class="nav-link"
                           href="/">

                            Home

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           href="#about">

                            About

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           href="#projects">

                            Projects

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           href="#contact">

                            Contact

                        </a>

                    </li>

                    <!-- AUTH -->

                    <AuthorizeView>

                        <Authorized>

                            <li class="nav-item ms-3">

                                <form action="/Account/Logout"
                                      method="post">

                                    <AntiforgeryToken />

                                    <button type="submit"
                                            class="login-btn">

                                        Logout

                                    </button>

                                </form>

                            </li>

                        </Authorized>

                        <NotAuthorized>

                            <li class="nav-item ms-3">

                                <NavLink class="login-btn"
                                         href="/Account/Login">

                                    Login

                                </NavLink>

                            </li>

                            <li class="nav-item ms-2">

                                <NavLink class="start-btn"
                                         href="/Account/Register">

                                    Get Started

                                </NavLink>

                            </li>

                        </NotAuthorized>

                    </AuthorizeView>

                </ul>

            </div>

        </div>

    </nav>

    <!-- PAGE -->

    <main>

        @Body

    </main>

</div>
@page "/Setup"

<h1 class="setup-title">
    Build Your Portfolio 🚀
</h1>

<p class="setup-subtitle">
    Add your details to generate your portfolio.
</p>

<div class="setup-container">

    <!-- BASIC INFO -->

    <div class="setup-card">

        <h2>
            Basic Information
        </h2>

        <div class="mb-3">

            <label>
                Full Name
            </label>

            <input class="form-control"
                   placeholder="Enter your name" />

        </div>

        <div class="mb-3">

            <label>
                Tagline
            </label>

            <input class="form-control"
                   placeholder="Frontend Developer" />

        </div>

        <div class="mb-3">

            <label>
                About You
            </label>

            <textarea class="form-control"
                      rows="5"
                      placeholder="Write about yourself"></textarea>

        </div>

    </div>

    <!-- CONTACT -->

    <div class="setup-card">

        <h2>
            Contact Details
        </h2>

        <div class="mb-3">

            <label>
                Email
            </label>

            <input class="form-control"
                   placeholder="Enter email" />

        </div>

        <div class="mb-3">

            <label>
                Phone
            </label>

            <input class="form-control"
                   placeholder="Enter phone number" />

        </div>

        <div class="mb-3">

            <label>
                GitHub
            </label>

            <input class="form-control"
                   placeholder="GitHub profile link" />

        </div>

        <div class="mb-3">

            <label>
                LinkedIn
            </label>

            <input class="form-control"
                   placeholder="LinkedIn profile link" />

        </div>

    </div>

    <!-- SKILLS -->

    <div class="setup-card">

        <h2>
            Skills
        </h2>

        <div class="mb-3">

            <input class="form-control"
                   placeholder="Add skill" />

        </div>

    </div>

    <!-- PROJECTS -->

    <div class="setup-card">

        <h2>
            Add Project
        </h2>

        <div class="mb-3">

            <label>
                Project Title
            </label>

            <input class="form-control"
                   placeholder="Portfolio Website" />

        </div>

        <div class="mb-3">

            <label>
                Description
            </label>

            <textarea class="form-control"
                      rows="4"
                      placeholder="Describe your project"></textarea>

        </div>

        <div class="mb-3">

            <label>
                GitHub Link
            </label>

            <input class="form-control"
                   placeholder="GitHub URL" />

        </div>

    </div>

    <!-- GENERATE -->

    <div class="text-center mt-5">

        <a href="/Portfolio"
               class="generate-btn">

            Generate Portfolio

        </a>

    </div>

</div>
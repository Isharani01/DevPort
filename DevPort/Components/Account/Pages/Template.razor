@page "/template"

<section class="canva-hero">

    <div class="hero-left">

        <p class="template-badge">
            ✨ Modern Portfolio Builder
        </p>

        <h1>
            Create Beautiful
            Developer Portfolios
        </h1>

        <p class="hero-text">

            Showcase your projects,
            skills and achievements
            with a stunning modern portfolio.

        </p>

        <div class="hero-buttons">

            <a href="/projects"
                   class="btn btn-primary btn-lg">

                Explore Projects

            </a>

            <a href="/profile"
                   class="btn btn-light btn-lg">

                My Profile

            </a>

        </div>

    </div>

    <div class="hero-right">

        <div class="template-card">

            <h3>🚀 Frontend Developer</h3>

            <p>
                Building elegant UI experiences
                using modern technologies.
            </p>

        </div>

        <div class="template-card small-card">

            <h4>🔥 Skills</h4>

            <p>Blazor • C# • HTML • CSS</p>

        </div>

    </div>

</section>

<!-- FEATURES -->

<section class="template-features">

    <div class="feature-box">

        <h3>🎨 Beautiful UI</h3>

        <p>
            Modern layouts inspired by premium websites.
        </p>

    </div>

    <div class="feature-box">

        <h3>⚡ Fast Performance</h3>

        <p>
            Responsive and optimized developer portfolios.
        </p>

    </div>

    <div class="feature-box">

        <h3>🌙 Dark Mode</h3>

        <p>
            Elegant dark and light theme support.
        </p>

    </div>

</section>
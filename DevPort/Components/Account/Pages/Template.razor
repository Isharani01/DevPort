@page "/Templates"

<section class="projects-section">

    <div class="container">

        <!-- TITLE -->

        <div class="section-title">

            <h2>
                Choose Your Portfolio Template
            </h2>

            <p>
                Select a professional template
                to start building your portfolio.
            </p>

        </div>

        <!-- TEMPLATE GRID -->

        <div class="projects-grid">

            <!-- TEMPLATE 1 -->

            <div class="project-card">

                <div class="template-preview purple-template">

                    <h4>
                        Modern Purple
                    </h4>

                </div>

                <h3 class="mt-4">
                    🚀 Modern Purple
                </h3>

                <p>
                    Elegant modern developer
                    portfolio with premium UI.
                </p>

                <ul class="template-features">

                    <li>
                        ✔ Premium Hero Section
                    </li>

                    <li>
                        ✔ Glassmorphism Cards
                    </li>

                    <li>
                        ✔ Purple Aesthetic UI
                    </li>

                </ul>

                <div class="hero-actions mt-4">

                    <a href="/Setup"
                           class="start-btn">

                        Use Template

                    </a>

                </div>

            </div>

            <!-- TEMPLATE 2 -->

            <div class="project-card">

                <div class="template-preview minimal-template">

                    <h4>
                        Minimal Professional
                    </h4>

                </div>

                <h3 class="mt-4">
                    💼 Minimal Professional
                </h3>

                <p>
                    Clean minimal layout
                    for developers and students.
                </p>

                <ul class="template-features">

                    <li>
                        ✔ Minimal Clean UI
                    </li>

                    <li>
                        ✔ Professional Layout
                    </li>

                    <li>
                        ✔ Recruiter Friendly
                    </li>

                </ul>

                <div class="hero-actions mt-4">

                    <a href="/Setup"
                           class="start-btn">

                        Use Template

                    </a>

                </div>

            </div>

            <!-- TEMPLATE 3 -->

            <div class="project-card">

                <div class="template-preview creative-template">

                    <h4>
                        Creative Designer
                    </h4>

                </div>

                <h3 class="mt-4">
                    🌈 Creative Designer
                </h3>

                <p>
                    Beautiful creative portfolio
                    for modern creators.
                </p>

                <ul class="template-features">

                    <li>
                        ✔ Colorful Design
                    </li>

                    <li>
                        ✔ Creative Sections
                    </li>

                    <li>
                        ✔ Designer Portfolio
                    </li>

                </ul>

                <div class="hero-actions mt-4">

                    <a href="/Setup"
                           class="start-btn">

                        Use Template

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>
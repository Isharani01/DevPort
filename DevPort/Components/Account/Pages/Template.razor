@page "/template"
@rendermode InteractiveServer
@inject DevPort.Services.TemplateService TemplateService
@inject NavigationManager Navigation
<section class="templates-page">

    <div class="templates-header">

        <p class="hero-badge">
            ✨ Premium Templates
        </p>

        <h1>
            Explore Beautiful Portfolio Designs
        </h1>

        <p>
            Choose modern layouts crafted for developers,
            designers and creators.
        </p>

    </div>

    <!-- TEMPLATE GRID -->

    <div class="template-grid">

        <!-- TEMPLATE 1 -->

        <div class="template-preview-card">

            <div class="template-preview one">

                <div class="mini-navbar"></div>

                <div class="mini-content">

                    <div class="mini-title"></div>

                    <div class="mini-text"></div>

                    <div class="mini-buttons">

                        <span></span>
                        <span></span>

                    </div>

                </div>

            </div>

            <div class="template-info">

                <h3>
                    Minimal Dark
                </h3>

                <p>
                    Elegant developer portfolio
                    with modern dark aesthetics.
                </p>

                <a href="/setup"
                       class="btn btn-primary">

                    Use Template

                </a>

            </div>

        </div>

        <!-- TEMPLATE 2 -->

        <div class="template-preview-card">

            <div class="template-preview two">

                <div class="glass-box"></div>

                <div class="glass-box small"></div>

            </div>

            <div class="template-info">

                <h3>
                    Glass UI
                </h3>

                <p>
                    Premium glassmorphism
                    portfolio experience.
                </p>

                <a href="/setup"
                       class="btn btn-primary">

                    Use Template

                </a>

            </div>

        </div>

        <!-- TEMPLATE 3 -->

        <div class="template-preview-card">

            <div class="template-preview three">

                <div class="gradient-circle"></div>

                <div class="gradient-circle second"></div>

            </div>

            <div class="template-info">

                <h3>
                    Creative Gradient
                </h3>

                <p>
                    Bold colorful layouts
                    for modern creators.
                </p>

                <a href="/setup"
                       class="btn btn-primary">

                    Use Template

                </a>

            </div>

        </div>

    </div>

</section>